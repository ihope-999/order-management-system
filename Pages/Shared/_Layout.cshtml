<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Order Management</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/project1.styles.css" asp-append-version="true" />

    <!-- Load foods.css only on Foods page -->
    @if (ViewContext.RouteData.Values["Page"]?.ToString() == "/Foods")
    {
        <link rel="stylesheet" href="~/css/foods.css" asp-append-version="true" />
    }
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold" asp-page="/Index">
                    <span style="color: var(--accent-primary); font-size: 1.25rem;">OrderHub</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon" style="filter: brightness(0.8);"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto ms-4">
                        <li class="nav-item"><a class="nav-link" asp-page="/Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Foods">Foods</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Cart">Cart</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Privacy">Privacy</a></li>
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link" asp-page="/CheckOrderedItems">Your Orders</a></li>

                        @if (User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-page="/RequestForRole">Requests</a></li>
                        }

                        <li class="nav-item"><a class="nav-link" asp-page="/AwaitingShipments">Shipments</a></li>

                        @if(User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item"><a class="nav-link" asp-page="/UserProfile">My Account</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Logout">Logout</a></li>
                        }

                        @if(!User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item"><a class="nav-link" asp-page="/Register">Register</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Login">Login</a></li>
                        }

                        @if(User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-page="/Requests">Admin Requests</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container-fluid">
        @RenderBody()
    </main>

    <footer class="footer text-center">
        <div class="container-fluid">
            <p class="mb-0">
                &copy; 2025 OrderHub - <a asp-page="/Privacy">Privacy Policy</a>
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

