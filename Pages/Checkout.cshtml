@page
@model project1.Pages.CheckoutModel

<style>
.checkout-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 0;
    animation: fadeIn 0.5s ease-out;
}

.checkout-header {
    margin-bottom: 3rem;
}

.checkout-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
}

.progress-indicator {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
}

.progress-step {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    background-color: var(--bg-tertiary);
    border-radius: var(--radius-md);
}

.progress-step.active {
    background-color: var(--accent-primary);
    color: white;
    font-weight: 600;
}

.step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    font-weight: bold;
}

.progress-step.active .step-number {
    background-color: rgba(255, 255, 255, 0.4);
}

.checkout-content {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 2rem;
}

.order-review {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.review-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    animation: slideInFromLeft 0.5s ease-out;
}

.review-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    margin-top: 0;
}

.order-items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.order-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    background-color: var(--bg-tertiary);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    transition: all var(--transition-base);
}

.order-item:hover {
    border-color: var(--accent-primary);
    background-color: var(--bg-hover);
}

.item-details h4 {
    font-size: 1.1rem;
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
}

.item-details p {
    margin: 0.25rem 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.item-price {
    text-align: right;
}

.item-price .price {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent-primary);
}

.item-price .quantity {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.order-summary {
    position: sticky;
    top: 100px;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 2rem;
    height: fit-content;
    animation: slideInFromRight 0.5s ease-out;
}

.summary-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 1.5rem;
}

.summary-row {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-color);
    font-size: 0.95rem;
    color: var(--text-secondary);
}

.summary-row.total {
    border-bottom: none;
    border-top: 2px solid var(--accent-primary);
    padding-top: 1rem;
    padding-bottom: 0;
    margin-top: 1rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
}

.summary-row.total .price {
    color: var(--accent-primary);
}

.checkout-button {
    width: 100%;
    padding: 1rem 1.5rem;
    background-color: var(--accent-primary);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all var(--transition-base);
    margin-top: 1.5rem;
}

.checkout-button:hover {
    background-color: var(--accent-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(59, 130, 246, 0.3);
}

@@media (max-width: 1024px) {
    .checkout-content {
        grid-template-columns: 1fr;
    }

    .order-summary {
        position: static;
    }
}

@@media (max-width: 1024px) {
    .checkout-header h1 {
        font-size: 1.75rem;
    }

    .progress-indicator {
        flex-wrap: wrap;
    }

    .order-item {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
    }

    .item-price {
        text-align: left;
        width: 100%;
    }
}

@@media (max-width: 480px) {
    .progress-indicator {
        display: none;
    }
}
</style>

<div class="checkout-container">
    <div class="checkout-header">
        <h1>Order Review</h1>
        <div class="progress-indicator">
            <div class="progress-step">
                <span class="step-number">1</span>
                <span>Cart</span>
            </div>
            <div style="color: var(--text-tertiary); margin: 0 0.5rem;">→</div>
            <div class="progress-step active">
                <span class="step-number">2</span>
                <span>Review</span>
            </div>
            <div style="color: var(--text-tertiary); margin: 0 0.5rem;">→</div>
            <div class="progress-step">
                <span class="step-number">3</span>
                <span>Payment</span>
            </div>
        </div>
    </div>

    <div class="checkout-content">
        <div class="order-review">
            <div class="review-card">
                <h3 class="review-title">Order Items</h3>
                <div class="order-items">
                    @foreach (var cartItem in Model.Cart.Items)
                    {
                        <div class="order-item">
                            <div class="item-details">
                                <h4>@cartItem.FoodName</h4>
                                <p><strong>Unit Price:</strong> $@cartItem.FoodPrice</p>
                                <p><strong>Quantity:</strong> @cartItem.CountOfItem unit(s)</p>
                            </div>
                            <div class="item-price">
                                <div class="price">$@(cartItem.FoodPrice * cartItem.CountOfItem)</div>
                                <div class="quantity">@cartItem.CountOfItem × $@cartItem.FoodPrice</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="order-summary">
            <h3 class="summary-title">Summary</h3>
            <div class="summary-row">
                <span>Subtotal</span>
                <span>$@Model.TotalPrice</span>
            </div>
            <div class="summary-row">
                <span>Shipping</span>
                <span>Free</span>
            </div>
            <div class="summary-row">
                <span>Tax</span>
                <span>Included</span>
            </div>
            <div class="summary-row total">
                <span>Total</span>
                <span class="price">$@Model.TotalPrice</span>
            </div>

            <form method="post">
                <button type="submit" class="checkout-button" asp-page-handler="BuyTheProducts">
                    Complete Purchase
                </button>
            </form>
        </div>
    </div>
</div>

