@page
@model project1.Pages.AwaitingShipmentsModel

<style>
.shipments-container {
    max-width: 1000px;
    margin: 0 auto;
    animation: fadeIn 0.5s ease-out;
}

.shipments-header {
    margin-bottom: 2rem;
}

.shipments-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
}

.count-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: var(--accent-primary);
    color: white;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.95rem;
}

.shipments-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 1.5rem;
}

.shipment-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: all var(--transition-base);
    animation: slideInFromLeft 0.5s ease-out;
}

.shipment-card:hover {
    border-color: var(--accent-primary);
    transform: translateY(-4px);
    box-shadow: 0 15px 40px rgba(59, 130, 246, 0.15);
}

.shipment-header {
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--border-color);
}

.shipment-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.5rem 0;
}

.shipment-details {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
}

.detail-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.detail-label {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.95rem;
}

.detail-value {
    color: var(--text-primary);
    font-weight: 600;
}

.quantity-badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    background-color: var(--bg-tertiary);
    color: var(--text-primary);
    border-radius: var(--radius-md);
    font-size: 0.85rem;
    font-weight: 600;
}

.action-button {
    width: 100%;
    padding: 0.75rem 1rem;
    background-color: var(--accent-secondary);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-base);
    margin-top: 1rem;
}

.action-button:hover {
    background-color: #059669;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.empty-shipments {
    text-align: center;
    padding: 3rem 2rem;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    color: var(--text-secondary);
}

.empty-shipments-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
}

@@media (max-width: 768px) {
    .shipments-header h1 {
        font-size: 1.75rem;
    }

    .shipments-list {
        grid-template-columns: 1fr;
    }
}
</style>

<div class="shipments-container">
    <div class="shipments-header">
        <h1>Awaiting Shipment</h1>
        @if(Model.cartItemsWaiting != null && Model.cartItemsWaiting.Count > 0)
        {
            <p>You have <span class="count-badge">@Model.cartItemsWaiting.Count()</span> item(s) waiting for shipment approval</p>
        }
        else
        {
            <p style="color: var(--text-secondary);">No items awaiting shipment approval</p>
        }
    </div>

    @{
        if(Model.cartItemsWaiting != null && Model.cartItemsWaiting.Count > 0)
        {
            <div class="shipments-list">
                @foreach(var item in Model.cartItemsWaiting)
                {
                    <div class="shipment-card">
                        <div class="shipment-header">
                            <h3 class="shipment-title">@item.FoodName</h3>
                        </div>

                        <div class="shipment-details">
                            <div class="detail-item">
                                <span class="detail-label">Quantity</span>
                                <span class="quantity-badge">@item.CountOfItem unit(s)</span>
                            </div>

                            <div class="detail-item">
                                <span class="detail-label">Price</span>
                                <span class="detail-value">$@item.FoodPrice</span>
                            </div>

                            <div class="detail-item">
                                <span class="detail-label">Delivery Address</span>
                                <span class="detail-value" style="font-size: 0.9rem;">@item.FoodDeliveryAddress</span>
                            </div>
                        </div>

                        <form method="post">
                            <button type="submit" class="action-button" 
                                    asp-route-id="@item.FoodId" 
                                    name="cartId" 
                                    value="@item.CartId"  
                                    asp-page-handler="ItemGivenToTheCargo">
                                ✓ Ready for Delivery
                            </button>
                        </form>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-shipments">
                <div class="empty-shipments-icon">📦</div>
                <h2 style="margin-top: 0;">No Shipments Pending</h2>
                <p>All your orders have been processed and are ready!</p>
            </div>
        }
    }
</div>
