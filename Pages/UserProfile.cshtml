@page
@using Microsoft.AspNetCore.Http
@model project1.Pages.UserProfileModel

<style>
.profile-container {
    max-width: 1200px;
    margin: 0 auto;
    animation: fadeIn 0.5s ease-out;
}

.profile-header {
    margin-bottom: 2rem;
}

.profile-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
}

.profile-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
}

.profile-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    animation: slideInFromLeft 0.5s ease-out;
}

.card-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--border-color);
}

.info-group {
    display: flex;
    flex-direction: column;
    margin-bottom: 1.5rem;
}

.info-label {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.4rem;
    font-weight: 600;
}

.info-value {
    font-size: 1.1rem;
    color: var(--text-primary);
    font-weight: 500;
    word-break: break-word;
}

.info-value.secondary {
    color: var(--text-secondary);
}

.admin-stats {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(16, 185, 129, 0.1) 100%);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin-bottom: 2rem;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
}

.stat-box {
    text-align: center;
}

.stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--accent-primary);
    line-height: 1;
    margin-bottom: 0.5rem;
}

.stat-label {
    color: var(--text-secondary);
    font-size: 0.95rem;
}

.role-badge {
    display: inline-block;
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-md);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background-color: var(--accent-primary);
    color: white;
    margin-bottom: 0.75rem;
}

.payment-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.payment-item {
    background-color: var(--bg-tertiary);
    padding: 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    transition: all var(--transition-base);
}

.payment-item:hover {
    border-color: var(--accent-primary);
    background-color: var(--bg-hover);
}

.payment-method {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

.payment-detail {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0.25rem 0;
}

.empty-state {
    text-align: center;
    padding: 2rem;
    color: var(--text-secondary);
}

.empty-state-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
}

@@media (max-width: 768px) {
    .profile-header h1 {
        font-size: 1.75rem;
    }

    .profile-grid {
        grid-template-columns: 1fr;
    }

    .stats-grid {
        grid-template-columns: 1fr;
    }
}
</style>

@{
    if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
    {
        <div class="admin-stats">
            <h2 style="margin-top: 0; margin-bottom: 1.5rem;">System Statistics</h2>
            <div class="stats-grid">
                <div class="stat-box">
                    <div class="stat-number">@Model._dbContext.Users.Count()</div>
                    <div class="stat-label">Total Users</div>
                </div>
                <div class="stat-box">
                    <div class="stat-number">@Model._dbContext.FoodItems.Count()</div>
                    <div class="stat-label">Food Items</div>
                </div>
            </div>
        </div>
    }

    if(User.Identity.IsAuthenticated)
    {
        <div class="profile-container">
            <div class="profile-header">
                <h1>My Account</h1>
                <p style="color: var(--text-secondary);">Manage your profile and payment information</p>
            </div>

            <div class="profile-grid">
                <!-- User Information -->
                <div class="profile-card">
                    <h3 class="card-title">Profile Information</h3>

                    <div class="info-group">
                        <span class="info-label">Name</span>
                        <span class="info-value">@Model.user.RealUserName</span>
                    </div>

                    <div class="info-group">
                        <span class="info-label">Email</span>
                        <span class="info-value secondary">@Model.user.Email</span>
                    </div>

                    <div class="info-group">
                        <span class="info-label">Phone</span>
                        <span class="info-value">@Model.user.TelNum</span>
                    </div>

                    @if(Model.roles != null && Model.roles.Count > 0)
                    {
                        <div class="info-group">
                            <span class="info-label">Roles</span>
                            <div>
                                @foreach(var role in Model.roles)
                                {
                                    <div class="role-badge">@role</div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <!-- Payment Information -->
                @if(Model.user.PaymentInfo != null && Model.user.PaymentInfo.Count > 0)
                {
                    <div class="profile-card">
                        <h3 class="card-title">Payment Methods</h3>
                        <div class="payment-list">
                            @foreach (var paymentinfo in Model.user.PaymentInfo)
                            {
                                <div class="payment-item">
                                    <div class="payment-method">
                                        @if(!string.IsNullOrEmpty(paymentinfo.PaymentProcessor))
                                        {
                                            <span>@paymentinfo.PaymentProcessor</span>
                                        }
                                        else
                                        {
                                            <span>Payment Method</span>
                                        }
                                    </div>

                                    @if(!string.IsNullOrEmpty(paymentinfo.CreditCardInfo))
                                    {
                                        <div class="payment-detail">
                                            <strong>Card:</strong> ••••••••@paymentinfo.CreditCardInfo.Substring(Math.Max(0, paymentinfo.CreditCardInfo.Length - 4))
                                        </div>
                                    }

                                    @if(!string.IsNullOrEmpty(paymentinfo.ShippingAddress))
                                    {
                                        <div class="payment-detail">
                                            <strong>Address:</strong> @paymentinfo.ShippingAddress
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="profile-card">
                        <h3 class="card-title">Payment Methods</h3>
                        <div class="empty-state">
                            <div class="empty-state-icon">💳</div>
                            <p>No payment methods saved yet</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}
