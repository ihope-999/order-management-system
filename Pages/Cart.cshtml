@page
@model project1.Pages.CartModel

<style>
.cart-container {
    max-width: 1200px;
    margin: 0 auto;
    animation: fadeIn 0.5s ease-out;
}

.cart-header {
    margin-bottom: 2rem;
}

.cart-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
}

.order-status {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(16, 185, 129, 0.1) 100%);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    border-left: 4px solid var(--accent-primary);
    font-weight: 600;
}

.cart-items {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.cart-item {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
    transition: all var(--transition-base);
    animation: slideInFromLeft 0.5s ease-out;
}

.cart-item:hover {
    border-color: var(--accent-primary);
    box-shadow: 0 10px 30px rgba(59, 130, 246, 0.15);
}

.item-details {
    display: grid;
    gap: 0.8rem;
}

.item-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
}

.item-info {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
}

.item-info span {
    display: flex;
    flex-direction: column;
}

.item-info strong {
    color: var(--text-primary);
    font-weight: 600;
}

.item-controls {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.quantity-control {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 0.5rem;
    width: fit-content;
}

.quantity-control button {
    background: none;
    border: none;
    color: var(--accent-primary);
    font-weight: bold;
    font-size: 1.25rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    transition: color var(--transition-fast);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.quantity-control button:hover {
    color: var(--accent-primary-hover);
}

.quantity-control input {
    width: 50px;
    text-align: center;
    background: none;
    border: none;
    color: var(--text-primary);
    font-weight: 600;
    padding: 0;
}

.quantity-control input:focus {
    outline: none;
}

.item-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.btn-delete {
    padding: 0.625rem 1rem;
    background-color: var(--accent-danger);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    font-size: 0.9rem;
}

.btn-delete:hover {
    background-color: #dc2626;
    transform: translateY(-2px);
}

.cart-summary {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin-left: auto;
    max-width: 400px;
    position: sticky;
    top: 100px;
}

.cart-summary h3 {
    font-size: 1.25rem;
    margin-top: 0;
    margin-bottom: 1.5rem;
}

.checkout-btn {
    width: 100%;
    padding: 0.875rem 1.5rem;
    background-color: var(--accent-primary);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all var(--transition-base);
}

.checkout-btn:hover {
    background-color: var(--accent-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
}

.empty-cart {
    text-align: center;
    padding: 3rem 2rem;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    color: var(--text-secondary);
}

.empty-cart h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
}

.empty-cart a {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 0.75rem 2rem;
    background-color: var(--accent-primary);
    color: white;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
}

.empty-cart a:hover {
    background-color: var(--accent-primary-hover);
    transform: translateY(-2px);
}

@@media (max-width: 1024px) {
    .cart-item {
        grid-template-columns: 1fr;
    }

    .item-controls {
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
    }

    .cart-summary {
        max-width: 100%;
        position: static;
        margin-left: 0;
        margin-top: 2rem;
    }
}

@@media (max-width: 640px) {
    .cart-header h1 {
        font-size: 1.75rem;
    }

    .item-info {
        gap: 1rem;
        font-size: 0.85rem;
    }

    .item-controls {
        flex-direction: column;
        align-items: flex-start;
    }
}
</style>

<div class="cart-container">
    <div class="cart-header">
        <h1>Shopping Cart</h1>
        <div class="order-status">
            Order Status: <strong>@(Model.Cart.Status.isOrdered ? "Ordered" : "Not Ordered")</strong>
        </div>
    </div>

    @{
        if(!Model.Cart.Status.isOrdered && Model.Cart.Items.Count > 0)
        {
            <div class="cart-items">
                @foreach(var cartItem in Model.Cart.Items)
                {
                    <div class="cart-item">
                        <div class="item-details">
                            <h3 class="item-name">@cartItem.FoodName</h3>
                            <div class="item-info">
                                <span>
                                    <strong>Price</strong>
                                    $@cartItem.FoodPrice
                                </span>
                                <span>
                                    <strong>Prep Time</strong>
                                    @cartItem.FoodTimeToMake min(s)
                                </span>
                                <span>
                                    <strong>Delivery</strong>
                                    ~@cartItem.FoodTimeToMakeTheDelivery min(s)
                                </span>
                            </div>
                        </div>

                        <div class="item-controls">
                            <div class="quantity-control">
                                <form method="post" style="margin: 0;">
                                    <button type="submit" asp-route-id="@cartItem.FoodId" asp-page-handler="DecreaseFoodCountByOne">−</button>
                                </form>
                                <input type="number" value="@cartItem.CountOfItem" min="1" readonly />
                                <form method="post" style="margin: 0;">
                                    <button type="submit" asp-route-id="@cartItem.FoodId" asp-page-handler="IncreaseFoodCountByOne">+</button>
                                </form>
                            </div>

                            <div class="item-actions">
                                <form method="post" style="margin: 0;">
                                    <button type="submit" class="btn-delete" asp-page-handler="DeleteFromTheCart" asp-route-id="@cartItem.FoodId">Remove</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="checkout-btn" style="max-width: 400px; margin-left: auto;">
                <form method="post">
                    <button type="submit" class="checkout-btn" asp-page-handler="GoToCheckOut">Proceed to Checkout</button>
                </form>
            </div>
        }
        else if(Model.Cart.Status.isOrdered)
        {
            <div class="empty-cart">
                <h2>✓ Order Confirmed</h2>
                <p>Your order has been placed successfully!</p>
                <a asp-page="/Foods">Continue Shopping</a>
            </div>
        }
        else
        {
            <div class="empty-cart">
                <h2>Your cart is empty</h2>
                <p>Start shopping to add items to your cart</p>
                <a asp-page="/Foods">Browse Foods</a>
            </div>
        }
    }
</div>