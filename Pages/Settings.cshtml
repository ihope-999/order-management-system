@page
@model project1.Pages.SettingsModel

<style>
.settings-container {
    max-width: 900px;
    margin: 0 auto;
    animation: fadeIn 0.5s ease-out;
}

.settings-header {
    margin-bottom: 2rem;
}

.settings-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
}

.settings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
}

.settings-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: all var(--transition-base);
}

.settings-card:hover {
    border-color: var(--accent-primary);
    box-shadow: var(--shadow-md);
}

.settings-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
}

.settings-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
}

.settings-description {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
}

.settings-button {
    display: inline-block;
    padding: 0.625rem 1.5rem;
    background-color: var(--accent-primary);
    color: white;
    text-decoration: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    transition: all var(--transition-base);
}

.settings-button:hover {
    background-color: var(--accent-primary-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

@@media (max-width: 768px) {
    .settings-header h1 {
        font-size: 1.75rem;
    }

    .settings-grid {
        grid-template-columns: 1fr;
    }
}
</style>

<div class="settings-container">
    <div class="settings-header">
        <h1>Settings</h1>
        <p style="color: var(--text-secondary);">Manage your account and preferences</p>
    </div>

    <div class="settings-grid">
        <div class="settings-card">
            <div class="settings-icon">👤</div>
            <h3 class="settings-title">Profile</h3>
            <p class="settings-description">
                Update your personal information and profile details.
            </p>
            <a asp-page="/UserProfile" class="settings-button">Go to Profile</a>
        </div>

        <div class="settings-card">
            <div class="settings-icon">🔐</div>
            <h3 class="settings-title">Security</h3>
            <p class="settings-description">
                Change your password and manage your security settings.
            </p>
            <a href="/" class="settings-button">Manage Security</a>
        </div>

        <div class="settings-card">
            <div class="settings-icon">🔔</div>
            <h3 class="settings-title">Notifications</h3>
            <p class="settings-description">
                Customize your notification preferences and alerts.
            </p>
            <a href="/" class="settings-button">Notification Settings</a>
        </div>

        <div class="settings-card">
            <div class="settings-icon">💳</div>
            <h3 class="settings-title">Payment Methods</h3>
            <p class="settings-description">
                Manage your saved payment methods and billing information.
            </p>
            <a href="/" class="settings-button">Manage Payments</a>
        </div>

        <div class="settings-card">
            <div class="settings-icon">🏠</div>
            <h3 class="settings-title">Addresses</h3>
            <p class="settings-description">
                Manage your saved delivery addresses.
            </p>
            <a href="/" class="settings-button">Manage Addresses</a>
        </div>

        <div class="settings-card">
            <div class="settings-icon">❓</div>
            <h3 class="settings-title">Help & Support</h3>
            <p class="settings-description">
                Get help with your account and common questions.
            </p>
            <a href="/" class="settings-button">Contact Support</a>
        </div>
    </div>
</div>
