@page
@model project1.Pages.LogoutModel

<style>
.logout-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 200px);
    padding: 2rem;
    animation: fadeIn 0.5s ease-out;
}

.logout-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 3rem 2rem;
    text-align: center;
    max-width: 500px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
}

.logout-icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
}

.logout-card h1 {
    font-size: 2rem;
    margin-top: 0;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--accent-secondary) 0%, #10b981 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.logout-message {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.6;
}

.logout-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.logout-actions a {
    display: inline-block;
    padding: 0.875rem 2rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-base);
}

.btn-home {
    background-color: var(--accent-primary);
    color: white;
}

.btn-home:hover {
    background-color: var(--accent-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
}

.btn-login {
    background-color: var(--bg-tertiary);
    color: var(--text-primary);
    border: 1px solid var(--border-color-light);
}

.btn-login:hover {
    background-color: var(--bg-hover);
    border-color: var(--text-secondary);
}
</style>

<div class="logout-container">
    <div class="logout-card">
        @if(User.Identity.IsAuthenticated)
        {
            <div class="logout-icon">👋</div>
            <h1>See you later, @User.Identity.Name!</h1>
            <p class="logout-message">
                You have been successfully logged out. Thank you for using our service. 
                Come back anytime to continue your orders.
            </p>
        }
        else
        {
            <div class="logout-icon">ℹ️</div>
            <h1>Not Logged In</h1>
            <p class="logout-message">
                You don't have an active session. Please log in to access your account 
                and place orders.
            </p>
        }

        <div class="logout-actions">
            <a asp-page="/Index" class="btn-home">Back to Home</a>
            <a asp-page="/Login" class="btn-login">Sign In</a>
        </div>
    </div>
</div>
